    - target: {fileID: 3971070249509788116, guid: 0d8fdc43102f189448e15eef36ca8165, type: 3}
      propertyPath: m_text
      value: "En esta casona de fines del siglo XVIII vivi\xF3 Esteban de Luca, militar,
        poeta, periodista y autor de la \"Marcha Patri\xF3tica\", primera canci\xF3n
        nacional compuesta en el a\xF1o 1810. Adem\xE1s, se destac\xF3 en la lucha
        contra las fuerzas inglesas que invadieron la ciudad en 1806 y 1807. La casa
        fue restaurada y conserva elementos arquitect\xF3nicos de la \xE9poca. Hoy
        es Monumento Hist\xF3rico Nacional."
      objectReference: {fileID: 0}
